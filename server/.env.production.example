# Production Environment Variables for Render
# Copy these values to Render dashboard > Environment

NODE_ENV=production
PORT=10000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com > Connect > Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/studyai?retryWrites=true&w=majority

# JWT secrets (generate strong random strings)
# Generate at: https://generate-secret.vercel.app/32
JWT_ACCESS_SECRET=<generate-min-32-char-random-string>
JWT_REFRESH_SECRET=<generate-min-32-char-random-string>

# OpenAI API key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-<your-key>

# Frontend URL (your Vercel deployment URL)
# Update after deploying frontend to Vercel
CLIENT_URL=https://your-app.vercel.app
